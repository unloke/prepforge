.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Local app data and engine binaries
data/
engines/
out/
*.db
*.sqlite
*.sqlite3

# Node / Vite frontend build tooling (build output in web/static IS committed)
node_modules/
.vite/
# Engine assets synced from node_modules by scripts/sync-stockfish.mjs; the
# BUILT copy under web/static/engine IS committed (Docker has no Node).
web-src/public/engine/
# Maia3 ONNX artifacts are generated by scripts/export_maia3_onnx.py and are too
# large for git (fp32 ~87MB, int8 ~24MB) — host them on a CDN/object store. The
# small manifest (hashes/versions/parity) IS tracked as the reproducibility record.
web-src/public/maia3/*.onnx
web-src/public/maia3/*.onnx.data
web-src/public/maia3/.stage-*/
web-src/public/maia3/.maia3.publish.lock
!web-src/public/maia3/maia3.manifest.json
# Safety net: a build copies public/ into the committed static dir; the Vite
# `exclude-maia3-weights` plugin strips the weights from the output, but never let
# them be committed even if that plugin is bypassed. The manifest still ships.
src/prepforge_chess/web/static/maia3/*.onnx
src/prepforge_chess/web/static/maia3/*.onnx.data

# Editor and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db
