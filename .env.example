# PrepForge Chess SaaS API — environment template.
# Copy to .env for local dev; set these as real env vars in production (Render).
# The legacy stdlib server does NOT use this file.

# development | production. Controls cookie Secure flag, HSTS, and /docs exposure.
PREPFORGE_ENV=development

# Strong random secret. REQUIRED in production (the app refuses to boot with the
# insecure default). Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
PREPFORGE_SECRET_KEY=dev-insecure-change-me

# SQLAlchemy database URL.
#   local dev/test : sqlite:///data/prepforge_api.sqlite3   (default if unset)
#   production      : postgresql+psycopg://USER:PASS@HOST:5432/prepforge
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/prepforge

# Browser origins allowed for CORS / future CSRF origin checks (comma-separated).
PREPFORGE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8765

# Session cookie tuning (optional).
# PREPFORGE_SESSION_COOKIE_NAME=pf_session
# PREPFORGE_SESSION_TTL_DAYS=30
# Max concurrent sessions per user (oldest pruned on new login; 0 disables).
# PREPFORGE_SESSION_MAX_PER_USER=10

# Observability (optional). Sentry stays dark unless a DSN is set AND sentry-sdk is
# installed (pip install sentry-sdk). Log level is INFO by default.
# PREPFORGE_SENTRY_DSN=
# PREPFORGE_LOG_LEVEL=INFO

# Stripe (billing). Billing routes 503 until STRIPE_SECRET_KEY is set; the webhook
# 503s until STRIPE_WEBHOOK_SECRET is set; Checkout needs STRIPE_PRICE_PRO (the Pro
# subscription price id, price_...). Leave empty to keep billing dark.
PREPFORGE_STRIPE_SECRET_KEY=
PREPFORGE_STRIPE_WEBHOOK_SECRET=
PREPFORGE_STRIPE_PRICE_PRO=

# Free-plan quota: max repertoires a Free user may own (Pro is unlimited).
PREPFORGE_FREE_REPERTOIRE_LIMIT=5
