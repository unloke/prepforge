{
  "name": "prepforge-chess-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PrepForge Chess web frontend (Vite build into the Python package's static dir).",
  "scripts": {
    "sync-engine": "node scripts/sync-stockfish.mjs && node scripts/sync-ort.mjs",
    "dev": "npm run sync-engine && vite",
    "build": "npm run sync-engine && vite build",
    "build:watch": "npm run sync-engine && vite build --watch",
    "preview": "vite preview",
    "smoke:two-origin": "node scripts/two-origin-smoke.mjs",
    "gate:cross-origin": "node scripts/run-provider-harness-headless.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "vite": "^6",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "onnxruntime-web": "^1.26.0",
    "stockfish": "^18.0.7"
  }
}
