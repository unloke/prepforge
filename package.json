{
  "name": "prepforge-chess-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PrepForge Chess web frontend (Vite build into the Python package's static dir).",
  "scripts": {
    "sync-engine": "node scripts/sync-stockfish.mjs",
    "dev": "npm run sync-engine && vite",
    "build": "npm run sync-engine && vite build",
    "build:watch": "npm run sync-engine && vite build --watch",
    "preview": "vite preview"
  },
  "devDependencies": {
    "vite": "^6"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "stockfish": "^18.0.7"
  }
}
